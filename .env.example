# Groq Cloud (Task 10 - Generation)
# Create a key at https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_xxx
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
RERANK_PROVIDER=groq

# Embeddings (Task 4/5)
# Groq chat models do not normally provide an embeddings endpoint.
# Configure an OpenAI-compatible embedding provider here; otherwise local hashing is used as fallback.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-xxx

# OpenRouter for DeepEval judge (Group Project Evaluation)
# Create a key at https://openrouter.ai/settings/keys
DEEPEVAL_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=Day08 RAG Evaluation

# OpenAI alternative (Task 10 - Generation)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# Jina AI (Task 7 - Reranking, optional)
JINA_API_KEY=jina_xxx

# PageIndex (Task 8 - Vectorless RAG)
PAGEINDEX_API_KEY=pi_xxx

# Weaviate Cloud (Task 4, optional - can use local Docker instead)
WEAVIATE_URL=https://xxx.weaviate.network
WEAVIATE_API_KEY=xxx

# Embedding model (if using API-based)
# COHERE_API_KEY=xxx
